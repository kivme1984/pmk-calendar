name = "pmk-google-auth"
main = "worker.js"
compatibility_date = "2026-07-04"

kv_namespaces = [
  { binding = "SESSION_KV", id = "PASTE_KV_NAMESPACE_ID" }
]

[vars]
ALLOWED_ORIGIN = "https://kivme1984.github.io"
DEFAULT_RETURN_TO = "https://kivme1984.github.io/pmk-calendar/"
GOOGLE_CLIENT_ID = "PASTE_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET задаётся только через secret:
# npx wrangler secret put GOOGLE_CLIENT_SECRET
